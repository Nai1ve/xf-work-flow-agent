    "meetingroom.booking.create": {
      "adapter_notes": [
        "tool spec lists both office_id and room_id as required, but simulator accepts either officeId-style office_id or room_id",
        "write must use a room candidate returned by meetingroom.room.list or meetingroom.room.schedule"
      ],
      "description": "创建会议室预订",
      "domain": "meetingroom",
      "name": "meetingroom.booking.create",
      "properties": {
        "attendees": {
          "minimum": 1,
          "type": "integer"
        },
        "day": {
          "format": "date",
          "type": "string"
        },
        "end": {
          "pattern": "^\\d{2}:\\d{2}$",
          "type": "string"
        },
        "office_id": {
          "type": "string"
        },
        "room_id": {
          "type": "string"
        },
        "start": {
          "pattern": "^\\d{2}:\\d{2}$",
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required_args": [
        "day",
        "office_id",
        "room_id",
        "start",
        "end",
        "title"
      ],
      "risk": "write"
    },
