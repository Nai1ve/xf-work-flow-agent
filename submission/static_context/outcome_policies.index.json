{
  "rules": [
    {
      "action": "workflow.search_person",
      "decision": "next_action",
      "id": "leave.search_approver_before_terminal",
      "priority": 200,
      "scope": "workflow.leave",
      "when": {
        "approver_hint_present": true,
        "approver_search_completed": false
      }
    },
    {
      "decision": "terminal",
      "id": "leave.ambiguous_approver",
      "priority": 180,
      "reason": "ambiguous_approver",
      "scope": "workflow.leave",
      "when": {
        "approver_candidate_count": {
          "ne": 1
        },
        "approver_search_completed": true
      }
    },
    {
      "decision": "terminal",
      "id": "expense.ambiguous_subclass",
      "priority": 170,
      "reason": "ambiguous_material_subclass",
      "scope": "workflow.expense_material",
      "when": {
        "save_completed": false,
        "specific_material_evidence": false,
        "subclass_query_completed": true
      }
    },
    {
      "decision": "terminal",
      "id": "expense.insufficient_amount_breakdown",
      "priority": 175,
      "reason": "insufficient_amount_breakdown",
      "scope": "workflow.expense_material",
      "when": {
        "explicit_multi_item_total_only": true,
        "save_completed": false
      }
    },
    {
      "decision": "terminal",
      "id": "expense.ambiguous_project",
      "priority": 160,
      "reason": "ambiguous_project",
      "scope": "workflow.expense_material",
      "when": {
        "project_candidate_count": {
          "gt": 1
        },
        "project_query_completed": true,
        "project_resolved": false
      }
    },
    {
      "decision": "terminal",
      "id": "meeting.no_bookable_room",
      "priority": 150,
      "reason": "no_bookable_room",
      "scope": "meetingroom",
      "when": {
        "bookable_room_count": 0,
        "booking_completed": false,
        "room_query_completed": true
      }
    }
  ],
  "schema_version": "outcome-policies-v1"
}
